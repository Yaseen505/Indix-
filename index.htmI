<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>INDIX V3</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;font-family:Arial,Helvetica,sans-serif}
body{background:#071120;color:#f8fafc}
button{cursor:pointer}
.login{min-height:100vh;display:flex;align-items:center;justify-content:center;background:radial-gradient(circle at top,#173b6d,#071120 55%)}
.card{width:92%;max-width:460px;background:rgba(15,31,53,.95);border:1px solid #29466e;border-radius:26px;padding:32px;box-shadow:0 25px 80px #0009}
.logo{font-size:52px;font-weight:900;text-align:center;color:#f7c948;letter-spacing:2px}
.sub{text-align:center;color:#b8c7dc;margin:12px 0 28px;line-height:1.5}
input,select,textarea{width:100%;padding:14px;margin:8px 0;border-radius:14px;border:1px solid #36577f;background:#081729;color:#fff;font-size:15px}
.btn{width:100%;padding:15px;border:0;border-radius:14px;background:#f7c948;color:#111;font-weight:900;margin-top:10px;font-size:16px}
.roles{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:16px}
.role{background:#132943;border:1px solid #36577f;border-radius:16px;padding:13px;text-align:center;color:#e5eefc}
.app{display:none;min-height:100vh}
.header{display:flex;justify-content:space-between;align-items:center;padding:18px 24px;background:#0d1c30;border-bottom:1px solid #29466e;position:sticky;top:0;z-index:10}
.header h1{color:#f7c948;letter-spacing:1px}
.layout{display:grid;grid-template-columns:250px 1fr;min-height:calc(100vh - 72px)}
.sidebar{background:#0b1829;padding:18px;border-left:1px solid #29466e}
.nav button{display:block;width:100%;text-align:right;margin:8px 0;padding:13px;border-radius:14px;border:1px solid #29466e;background:#10243b;color:#fff;font-weight:700}
.nav button:hover,.active{background:#f7c948!important;color:#111!important}
.main{padding:24px;max-width:1400px}
h2{font-size:28px;margin-bottom:6px}
.muted{color:#b8c7dc;line-height:1.6}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:16px;margin:18px 0}
.box{background:#10243b;border:1px solid #29466e;border-radius:20px;padding:18px;box-shadow:0 10px 30px #0003}
.box h3{color:#f7c948;margin-bottom:10px}
.project{display:flex;justify-content:space-between;gap:12px;align-items:center;margin:12px 0;padding:16px;border-radius:16px;background:#0b1829;border:1px solid #29466e}
.green{color:#44d07b}.yellow{color:#f7c948}.red{color:#ff5c5c}.blue{color:#4aa3ff}.gray{color:#a7b0bd}
.badge{display:inline-block;padding:6px 10px;border-radius:22px;background:#1a3555;font-size:13px;margin:3px}
.plan{height:560px;background:#020711;border:1px solid #29466e;border-radius:22px;position:relative;overflow:hidden;margin-top:18px;background-image:linear-gradient(135deg,rgba(255,255,255,.04) 1px,transparent 1px);background-size:18px 18px}
.road{position:absolute;background:#9c4dff;height:72px;width:82%;top:250px;right:8%;transform:rotate(-20deg);border:6px solid #ff3fd4;border-radius:20px}
.sidewalk{position:absolute;background:#45d07b66;height:110px;width:48%;top:270px;right:10%;transform:rotate(-20deg);border:2px dashed #44d07b}
.line{position:absolute;height:10px;border-radius:20px}
.done{background:#44d07b}.issue{background:#ff4545}.pending{background:#777}.material{background:#4aa3ff}
.pole{position:absolute;width:30px;height:30px;border-radius:50%;background:#f7c948;border:3px solid #fff;box-shadow:0 0 20px #f7c94899}
.asset-card{position:absolute;background:#10243bee;border:1px solid #f7c948;border-radius:16px;padding:14px;width:260px;left:22px;top:22px;line-height:1.5}
.timeline li{margin:10px 0;padding:14px;background:#0b1829;border-radius:14px;border:1px solid #29466e;list-style:none}
.table{width:100%;border-collapse:collapse;margin-top:12px;overflow:hidden;border-radius:16px}
.table th,.table td{border-bottom:1px solid #29466e;padding:13px;text-align:right}
.table th{color:#f7c948;background:#0b1829}
.actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px}
.small-btn{padding:10px 12px;border-radius:12px;border:1px solid #36577f;background:#132943;color:#fff}
@media(max-width:850px){.layout{grid-template-columns:1fr}.sidebar{border-left:0}.roles{grid-template-columns:1fr}.plan{height:470px}.header{align-items:flex-start;gap:10px;flex-direction:column}}
</style>
</head>
<body>

<section id="login" class="login">
  <div class="card">
    <div class="logo">INDIX</div>
    <div class="sub">מערכת חכמה לניהול תשתיות, תאורה, רמזורים, כבישים ומחסן</div>
    <input placeholder="אימייל" value="owner@indix.co.il">
    <input placeholder="סיסמה" type="password" value="123456">
    <select id="role">
      <option>בעל החברה</option>
      <option>מהנדס</option>
      <option>מנהל עבודה</option>
      <option>עובד</option>
      <option>מחסנאי</option>
    </select>
    <button class="btn" onclick="openApp()">התחבר</button>
    <div class="roles">
      <div class="role">👑 בעל חברה</div>
      <div class="role">👷 מהנדס</div>
      <div class="role">👷‍♂️ עובד</div>
      <div class="role">📦 מחסנאי</div>
    </div>
  </div>
</section>

<section id="app" class="app">
  <div class="header">
    <h1>INDIX V3</h1>
    <div>מחובר כ־ <b id="userRole">בעל החברה</b></div>
  </div>

  <div class="layout">
    <aside class="sidebar">
      <div class="nav">
        <button class="active" onclick="show('dashboard',this)">📊 דשבורד</button>
        <button onclick="show('projects',this)">📁 פרויקטים</button>
        <button onclick="show('plans',this)">📐 תוכניות חכמות</button>
        <button onclick="show('inventory',this)">📦 מחסן</button>
        <button onclick="show('assets',this)">💡 נכסים</button>
        <button onclick="show('workers',this)">👷 עובדים</button>
        <button onclick="show('reports',this)">📋 דיווחי שטח</button>
      </div>
    </aside>

    <main class="main">
      <div id="dashboard" class="page">
        <h2>דשבורד ראשי</h2>
        <p class="muted">תמונת מצב מהירה של כל הפרויקטים, המחסן, העובדים והתקלות.</p>
        <div class="grid">
          <div class="box"><h3>18</h3><p>סה"כ פרויקטים</p></div>
          <div class="box"><h3>12</h3><p>פרויקטים פעילים</p></div>
          <div class="box"><h3>46</h3><p>עובדים בשטח</p></div>
          <div class="box"><h3>3,280</h3><p>פריטים במחסן</p></div>
        </div>
        <div class="box">
          <h3>מפת סטטוס פרויקטים</h3>
          <p>🟢 פרויקט ארד רננים — תקין</p>
          <p>🟡 כביש 25-27 — חסר חומר</p>
          <p>🔴 צומת דימונה — תקלה בשטח</p>
        </div>
      </div>

      <div id="projects" class="page" style="display:none">
        <h2>ניהול פרויקטים</h2>
        <p class="muted">פתיחת פרויקטים, שיוך מהנדס, עובדים, תוכניות, חומרים ודוחות.</p>
        <div class="project"><b>פרויקט ארד רננים</b><span class="green">85% בוצע</span></div>
        <div class="project"><b>כביש 25-27</b><span class="yellow">42% בביצוע</span></div>
        <div class="project"><b>צומת דימונה</b><span class="red">תקלה</span></div>
        <button class="btn">+ פתיחת פרויקט חדש</button>
      </div>

      <div id="plans" class="page" style="display:none">
        <h2>תוכניות חכמות DWG / PDF</h2>
        <p class="muted">המהנדס מעלה תוכנית, מסמן חציות, עמודים, תעלות וכבלים. העובד רואה בשטח מה לבצע ומדווח על כל נקודה.</p>
        <div class="actions">
          <button class="small-btn">⬆️ העלאת DWG/PDF</button>
          <button class="small-btn">✏️ סימון חציה</button>
          <button class="small-btn">📏 מדידה</button>
          <button class="small-btn">🧱 שכבות</button>
        </div>
        <div class="plan">
          <div class="sidewalk"></div>
          <div class="road"></div>
          <div class="line done" style="width:245px;top:160px;right:90px;transform:rotate(-25deg)"></div>
          <div class="line done" style="width:185px;top:255px;right:315px;transform:rotate(-25deg)"></div>
          <div class="line issue" style="width:150px;top:342px;right:500px;transform:rotate(-25deg)"></div>
          <div class="line material" style="width:135px;top:110px;right:540px;transform:rotate(-25deg)"></div>
          <div class="pole" style="top:128px;right:180px"></div>
          <div class="pole" style="top:220px;right:360px"></div>
          <div class="pole" style="top:314px;right:555px"></div>
          <div class="asset-card">
            <b>חציה 3</b><br><br>
            סטטוס: <span class="red">לא בוצע</span><br>
            סיבה: קו מים מתחת לנקודת החפירה<br>
            עובד: אחמד<br>
            פעולה: נשלחה התראה למהנדס<br><br>
            <span class="badge">📷 תמונה</span>
            <span class="badge">📍 GPS</span>
          </div>
        </div>
      </div>

      <div id="inventory" class="page" style="display:none">
        <h2>מחסן</h2>
        <p class="muted">כניסת סחורה, יציאה לשטח, החזרה, חתימה ושיוך לפרויקט.</p>
        <div class="grid">
          <div class="box"><h3>פנסים</h3><p>נמצא: 120 | יצא: 70 | חזר: 10</p></div>
          <div class="box"><h3>עמודי תאורה</h3><p>נמצא: 55 | הותקן: 24</p></div>
          <div class="box"><h3>כבלים</h3><p>נמצא: 3,800 מטר</p></div>
          <div class="box"><h3>ארונות חשמל</h3><p>נמצא: 12</p></div>
        </div>
        <table class="table">
          <tr><th>תאריך</th><th>פריט</th><th>פעולה</th><th>פרויקט</th><th>חתימה</th></tr>
          <tr><td>28/06</td><td>70 פנסים</td><td>יציאה</td><td>ארד רננים</td><td>חתום</td></tr>
          <tr><td>28/06</td><td>10 פנסים</td><td>החזרה</td><td>ארד רננים</td><td>חתום</td></tr>
        </table>
      </div>

      <div id="assets" class="page" style="display:none">
        <h2>Asset Management — ניהול נכסים</h2>
        <p class="muted">כל עמוד, פנס, רמזור, ארון חשמל וחציה מקבלים כרטיס חיים מלא.</p>
        <div class="grid">
          <div class="box"><h3>עמוד 254</h3><p>סטטוס: <span class="green">הותקן</span></p><p>תמונות: לפני / אחרי</p></div>
          <div class="box"><h3>חציה 2.5</h3><p>סטטוס: <span class="red">תקלה</span></p><p>סיבה: קו מים</p></div>
          <div class="box"><h3>ארון חשמל A17</h3><p>סטטוס: <span class="yellow">בבדיקה</span></p></div>
          <div class="box"><h3>רמזור R-08</h3><p>סטטוס: <span class="blue">מחכה לחומר</span></p></div>
        </div>
      </div>

      <div id="workers" class="page" style="display:none">
        <h2>עובדים והרשאות</h2>
        <p class="muted">לכל עובד יש גישה רק למשימות ולתוכניות שהמהנדס שייך אליו.</p>
        <div class="project"><b>אחמד</b><span>משימות היום: 4</span></div>
        <div class="project"><b>יוסף</b><span>משימות היום: 3</span></div>
        <div class="project"><b>מחמוד</b><span class="yellow">ממתין לאישור</span></div>
      </div>

      <div id="reports" class="page" style="display:none">
        <h2>דיווחי שטח ו־Timeline</h2>
        <ul class="timeline">
          <li>📅 28/06/2026 — עובד דיווח: בוצעו 2 חציות מתוך 3</li>
          <li>📷 28/06/2026 — הועלו 12 תמונות מהשטח</li>
          <li>⚠️ 28/06/2026 — חציה שלישית לא בוצעה בגלל קו מים</li>
          <li>💡 27/06/2026 — הותקנו 24 עמודי תאורה</li>
        </ul>
        <textarea placeholder="העובד יכול לרשום כאן למה עבודה לא בוצעה..."></textarea>
        <button class="btn">שלח דיווח למהנדס</button>
      </div>
    </main>
  </div>
</section>

<script>
function openApp(){
  document.getElementById('login').style.display='none';
  document.getElementById('app').style.display='block';
  document.getElementById('userRole').innerText=document.getElementById('role').value;
}
function show(id,btn){
  document.querySelectorAll('.page').forEach(p=>p.style.display='none');
  document.getElementById(id).style.display='block';
  document.querySelectorAll('.nav button').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}
</script>
</body>
</html>
